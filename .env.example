# =========================================
# Spring Boot
# =========================================

SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/dev_support
SPRING_DATASOURCE_USERNAME=dev_support_user
SPRING_DATASOURCE_PASSWORD=dev_support_password

SPRING_MAIL_HOST=localhost
SPRING_MAIL_PORT=1025