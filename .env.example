# =========================================
# MySQL
# =========================================

MYSQL_DATABASE=dev_support
MYSQL_USER=dev_support_user
MYSQL_PASSWORD=dev_support_password
MYSQL_ROOT_PASSWORD=dev_support_root_password
MYSQL_PORT=3306

# =========================================
# Mailpit
# =========================================

MAILPIT_SMTP_PORT=1025
